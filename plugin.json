{
  "id": "json-formatter",
  "name": "JSON 格式化",
  "version": "1.0.0",
  "author": "ActionQuick",
  "description": "格式化、压缩、校验 JSON",
  "icon": "icon.png",
  "main": "index.html",
  "keywords": ["json", "格式化", "format", "jSON"],
  "context": {
    "text": {
      "pattern": "^\\s*[\\[\\{]",
      "label": "JSON"
    }
  },
  "permissions": ["clipboard"],
  "minHostVersion": "0.1.0"
}
